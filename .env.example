# Copy to `.env.local` and replace placeholders with Supabase Dashboard → Settings → API.
# Restart `npm run dev` after edits. On Vercel, add these under Project → Settings → Environment Variables and redeploy (`NEXT_PUBLIC_*` are inlined at client build time).

NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_URL=your-supabase-project-url
SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: absolute app URL when behind proxies (quotes, signup redirect)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Used by scripts / admin APIs (never expose to browser)
# SUPABASE_SERVICE_ROLE_KEY=

# Stripe, email, SMS (enable when you wire those features)
# STRIPE_SECRET_KEY=
# STRIPE_PRICE_ID=
# STRIPE_WEBHOOK_SECRET=
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
