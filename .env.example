# Copy to .env.local and fill from Supabase → Project Settings → API
# Redeploy Vercel after changing NEXT_PUBLIC_* (embedded at build).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Optional but recommended on Vercel: duplicate values for OAuth + server signup (reads at RUNTIME — fixes Google without client-bundle env).
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_ANON_KEY=your_anon_key
